---
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10002b" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const themeMeta = document.querySelector('meta[name="theme-color"]');
        const media = window.matchMedia('(prefers-color-scheme: light)');
        const resolveTheme = () => {
          const stored = localStorage.getItem('theme');
          if (stored === 'light' || stored === 'dark') return stored;
          return media.matches ? 'light' : 'dark';
        };
        const setTheme = (theme) => {
          root.dataset.theme = theme;
          if (themeMeta) {
            themeMeta.setAttribute('content', theme === 'light' ? '#f7edff' : '#10002b');
          }
        };
        window.__setPreferredTheme = (theme) => {
          localStorage.setItem('theme', theme);
          setTheme(theme);
        };
        setTheme(resolveTheme());
        window.addEventListener('DOMContentLoaded', () => {
          requestAnimationFrame(() => root.classList.add('theme-ready'));
        });
      })();
    </script>
  </head>
  <body class="min-h-dvh overflow-x-hidden font-sans text-[var(--text)] antialiased" style="background: var(--bg);">
    <!-- Fixed ambient layer — z-index 0, pointer-events none, content sits above at z-10 -->
    <div
      class="pointer-events-none fixed inset-0 z-0 overflow-hidden"
      aria-hidden="true"
    >
      <!-- base page bg so content area underneath is opaque -->
      <div class="absolute inset-0" style="background: var(--bg);"></div>

      <!-- blobs -->
      <div class="ambient-blob ambient-blob-1 absolute -left-32 top-[-4rem] h-[52rem] w-[52rem]"></div>
      <div class="ambient-blob ambient-blob-2 absolute -right-32 top-[12%] h-[46rem] w-[46rem]"></div>
      <div class="ambient-blob ambient-blob-3 absolute left-1/2 top-[52%] h-[40rem] w-[40rem] -translate-x-1/2"></div>
      <div class="ambient-blob ambient-blob-4 absolute right-[6%] top-[28%] h-[28rem] w-[28rem]"></div>

      <!-- aurora, ribbon -->
      <div class="ambient-aurora"></div>
      <div class="ambient-ribbon"></div>

      <!-- particle canvas -->
      <canvas id="particle-canvas" class="absolute inset-0 h-full w-full"></canvas>
    </div>

    <!-- page content sits above the background layer -->
    <div class="relative z-10">
      <slot />
    </div>

    <!-- Particle system -->
    <script is:inline>
      (function () {
        const canvas = document.getElementById('particle-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');

        // Pull CSS custom properties for colours
        const style = getComputedStyle(document.documentElement);
        const getVar = (v) => style.getPropertyValue(v).trim();

        // Particle config
        const COUNT = 72;
        const particles = [];

        function resize() {
          canvas.width  = window.innerWidth;
          canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        // Each particle: position, velocity, size, colour, opacity, phase
        function mkParticle() {
          const palette = [
            getVar('--palette-primary-anchor')   || '#9d4edd',
            getVar('--palette-neon-anchor')       || '#00ffb2',
            getVar('--palette-secondary-anchor')  || '#5a189a',
            getVar('--palette-neutral-12')        || '#ffffff',
          ];
          const isNeon   = Math.random() < 0.28;
          const isBright = Math.random() < 0.15;
          return {
            x:     Math.random() * (canvas.width  || window.innerWidth),
            y:     Math.random() * (canvas.height || window.innerHeight),
            vx:    (Math.random() - 0.5) * 0.10,   // very slow drift
            vy:    (Math.random() - 0.5) * 0.08,
            r:     isBright ? Math.random() * 2.2 + 1.2 : Math.random() * 1.2 + 0.3,
            color: isNeon ? palette[1] : palette[Math.floor(Math.random() * palette.length)],
            baseAlpha: isBright ? 0.7 : Math.random() * 0.38 + 0.08,
            alpha:  0,
            phase:  Math.random() * Math.PI * 2,   // for twinkle
            speed:  Math.random() * 0.007 + 0.002, // twinkle speed
            glowR:  isBright ? 18 : Math.random() * 8 + 3,
          };
        }

        for (let i = 0; i < COUNT; i++) {
          particles.push(mkParticle());
        }

        let frame;
        let t = 0;

        function draw() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          t += 1;

          for (const p of particles) {
            // Twinkle: sine wave on alpha
            p.alpha = p.baseAlpha * (0.5 + 0.5 * Math.sin(t * p.speed + p.phase));

            // Drift
            p.x += p.vx;
            p.y += p.vy;

            // Soft wrap-around with fade margin
            const margin = 60;
            if (p.x < -margin) p.x = canvas.width  + margin;
            if (p.x > canvas.width  + margin) p.x = -margin;
            if (p.y < -margin) p.y = canvas.height + margin;
            if (p.y > canvas.height + margin) p.y = -margin;

            // Glow halo
            const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.glowR);
            grd.addColorStop(0,   hexAlpha(p.color, p.alpha));
            grd.addColorStop(0.4, hexAlpha(p.color, p.alpha * 0.4));
            grd.addColorStop(1,   hexAlpha(p.color, 0));

            ctx.beginPath();
            ctx.arc(p.x, p.y, p.glowR, 0, Math.PI * 2);
            ctx.fillStyle = grd;
            ctx.fill();

            // Core dot
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = hexAlpha(p.color, Math.min(p.alpha * 1.8, 1));
            ctx.fill();
          }

          frame = requestAnimationFrame(draw);
        }

        // Hex + alpha helper
        function hexAlpha(hex, a) {
          // hex can be #rrggbb or a CSS colour name
          let r = 160, g = 80, b = 220;
          const m = hex.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
          if (m) { r = parseInt(m[1],16); g = parseInt(m[2],16); b = parseInt(m[3],16); }
          return `rgba(${r},${g},${b},${Math.max(0, Math.min(1, a)).toFixed(3)})`;
        }

        // Respect reduce-motion
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          draw();
        }

        // Pause when tab hidden, resume on visible
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) { cancelAnimationFrame(frame); }
          else if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) { draw(); }
        });
      })();
    </script>

    <!-- Scroll-reveal observer -->
    <script is:inline>
      (function () {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('revealed');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -60px 0px', threshold: 0.08 }
        );
        const bind = () =>
          document
            .querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale')
            .forEach((el) => io.observe(el));
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', bind);
        } else {
          bind();
        }
      })();
    </script>
  </body>
</html>

---
import type { ProjectCard as ProjectCardType } from '../data/profile';

type Props = { project: ProjectCardType; revealClass?: string };

const { project, revealClass = 'reveal' } = Astro.props;
---

<article
  class:list={[
    revealClass,
    'group panel-surface flex w-full flex-col p-6 transition duration-300 hover:-translate-y-1 hover:border-[var(--neon)]/35 hover:shadow-[0_30px_70px_-42px_var(--shadow-strong)]',
    project.featured && 'panel-surface-strong lg:p-8',
  ]}
>
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <span
      class="rounded-full border border-[var(--accent)]/25 bg-[var(--accent)]/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--accent)]"
    >
      {project.status}
    </span>
    {
      project.tags.map((tag) => (
        <span class="rounded-full border border-[var(--glass-border)] bg-[var(--surface-soft)] px-3 py-1 text-xs text-[var(--text-muted)] transition duration-300 hover:border-[var(--neon)]/35 hover:text-[var(--neon)]">
          {tag}
        </span>
      ))
    }
  </div>
  <h3
    class:list={[
      'font-display font-semibold tracking-tight text-[var(--text)]',
      project.featured ? 'text-2xl sm:text-3xl' : 'text-xl',
    ]}
  >
    {project.title}
  </h3>
  <p class="mt-3 line-clamp-4 flex-1 text-sm leading-7 text-[var(--text-muted)] sm:text-base">
    {project.description}
  </p>
  <div class="mt-6 flex flex-wrap gap-3">
    {
      project.links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--glass-border)] bg-[var(--glass)] px-4 py-2 text-sm font-semibold text-[var(--accent)] transition duration-300 hover:border-[var(--accent)]/35 hover:bg-[var(--glass-elevated)]"
        >
          {link.label}
          <span aria-hidden="true">↗</span>
        </a>
      ))
    }
  </div>
</article>

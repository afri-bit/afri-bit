---
type Props = {
  title: string;
  body: string;
  buttonLabel: string;
  buttonHref: string;
};

const { title, body, buttonLabel, buttonHref } = Astro.props;
---

<section id="contact" class="scroll-mt-24 pb-24 pt-4">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div
      class="reveal panel-surface panel-surface-strong relative overflow-hidden p-8 sm:p-10 lg:p-12"
    >
      <div
        class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[var(--accent)]/20 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute left-[-10%] top-[58%] h-52 w-52 rounded-full bg-[var(--accent-tertiary)]/12 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="reveal stagger-2 relative">
        <p class="section-eyebrow">Let&apos;s build</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[var(--text)] sm:text-4xl">
          {title}
        </h2>
        <p class="mt-4 text-lg leading-8 text-[var(--text-muted)]">{body}</p>
        <a
          href={buttonHref}
          target="_blank"
          rel="noreferrer noopener"
          class="mt-8 inline-flex items-center justify-center rounded-2xl bg-[var(--text)] px-6 py-3.5 text-sm font-semibold text-[var(--bg)] transition duration-300 hover:-translate-y-0.5 hover:brightness-95"
        >
          {buttonLabel}
        </a>
      </div>
    </div>
  </div>
</section>
